#Cmp（2bit Comparator）
# Inputs : a1 a0 b1 b0
# Outputs: g e l z (z は常に0)

# A: a1a0,  B:b1b0
# g : A > B
# e : A = B
# l : A < B

.i 4
.o 3
.ilb a1 a0 b1 b0
.ob g e l
